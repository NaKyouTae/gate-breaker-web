{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@gate-breaker/types": ["./packages/types/src/index.ts"],
      "@gate-breaker/api-client": ["./packages/api-client/src/index.ts"],
      "@gate-breaker/ui": ["./packages/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
